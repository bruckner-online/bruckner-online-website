---
interface Props {
	id: string;
	presentationPath: string;
}

const { id, presentationPath } = Astro.props;

const manifestId = id ?? "WAB001";
---

<mirador-viewer
	id="mirador-viewer"
	data-presentation-path={presentationPath}
	data-imageid={manifestId}
	style="height: 600px;"></mirador-viewer>

<script>
	// @ts-expect-error No type definitions available for mirador
	import Mirador from "mirador";

	class MiradorViewer extends HTMLElement {
		connectedCallback() {
			Mirador.viewer({
				id: "mirador-viewer",
				showAddFromURLBox: false,
				windows: [
					{
						loadedManifest: `https://iiifpresentation.acdh.oeaw.ac.at/${this.dataset.presentationPath}/${this.dataset.imageid}/manifest`,
					},
				],
			});
		}
	}

	customElements.define("mirador-viewer", MiradorViewer);
</script>
